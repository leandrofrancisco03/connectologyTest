---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { Calendar, ArrowRight, Tag } from 'lucide-react';

const title = "Blog de automatización con IA, n8n y agentes | ConnectologyIA";
const description = "Guías, comparativas y casos prácticos sobre n8n, agentes de IA, Python y automatización de procesos empresariales.";

const allPosts = await getCollection('blog', ({ data }) => {
  return data.draft !== true;
});
allPosts.sort((a: any, b: any) => b.data.datePublished.valueOf() - a.data.datePublished.valueOf());
---

<Layout title={title} description={description}>
  <main id="main-content" class="pt-24 pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h1 class="text-4xl font-extrabold text-white mb-4">Blog y Recursos</h1>
        <p class="text-xl text-slate-400 max-w-2xl mx-auto">
          Insights, guías y casos de estudio sobre Inteligencia Artificial y automatización.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {allPosts.map((post: any) => (
          <article class="bg-slate-900/40 border border-slate-800 rounded-2xl overflow-hidden hover:border-cyan-500/50 transition-colors group flex flex-col">
            {post.data.image ? (
              <div class="aspect-video w-full overflow-hidden">
                <img 
                  src={post.data.image} 
                  alt={post.data.imageAlt || post.data.title} 
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
              </div>
            ) : (
              <div class="aspect-video w-full bg-slate-800 flex items-center justify-center">
                <span class="text-slate-500">Sin imagen</span>
              </div>
            )}
            
            <div class="p-6 flex-grow flex flex-col">
              <div class="flex items-center gap-4 text-sm text-slate-400 mb-4">
                <span class="flex items-center gap-1 bg-slate-800 px-2 py-1 rounded-md">
                  <Tag className="w-4 h-4" />
                  {post.data.category}
                </span>
                <span class="flex items-center gap-1">
                  <Calendar className="w-4 h-4" />
                  {post.data.datePublished.toLocaleDateString('es-PE', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric'
                  })}
                </span>
              </div>
              
              <h2 class="text-xl font-bold text-white mb-3 line-clamp-2 group-hover:text-cyan-400 transition-colors">
                <a href={`/blog/${post.slug}`}>{post.data.title}</a>
              </h2>
              
              <p class="text-slate-400 mb-6 line-clamp-3 flex-grow">
                {post.data.description}
              </p>
              
              <a href={`/blog/${post.slug}`} class="inline-flex items-center text-sm font-medium text-cyan-400 hover:text-cyan-300">
                Leer artículo <ArrowRight className="w-4 h-4 ml-1" />
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </main>
</Layout>
