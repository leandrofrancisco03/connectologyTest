---
import Layout from '../layouts/Layout.astro';

const title = "Página no encontrada | ConnectologyIA";
const description = "La página que buscas no existe o ha sido movida.";
---

<Layout title={title} description={description}>
  <main id="main-content" class="pt-32 pb-24 flex-grow flex flex-col items-center justify-center text-center px-4">
    <h1 class="text-6xl font-extrabold text-cyan-400 mb-4">404</h1>
    <h2 class="text-3xl font-bold text-white mb-6">Página no encontrada</h2>
    <p class="text-slate-400 max-w-md mx-auto mb-8">
      Lo sentimos, no pudimos encontrar la página que estás buscando. Puede que haya sido movida o eliminada.
    </p>
    <a href="/" class="bg-cyan-500 text-white font-medium px-8 py-3 rounded-full hover:bg-cyan-600 transition-colors">
      Volver al Inicio
    </a>
  </main>
</Layout>
