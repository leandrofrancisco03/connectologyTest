---
import { Navbar } from '../components/Navbar.tsx';
import { Footer } from '../components/Footer.tsx';
import { WhatsAppButton } from '../components/WhatsAppButton.tsx';
import '../index.css';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogType?: string;
  ogImage?: string;
}

const { 
  title, 
  description = "Automatizamos tu negocio con Agentes IA, n8n y Python. Workflows inteligentes a medida. ¿Listo para ahorrar tiempo y escalar? Contáctanos hoy.", 
  canonical = Astro.url.href,
  ogType = "website",
  ogImage = "/favicon.png"
} = Astro.props;

const currentPath = Astro.url.pathname;
const siteUrl = "https://connectologyia.pages.dev";
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />
    <meta name="google-site-verification" content="9Wn4rJV03gGH9VbX2hHatur5tdjDyPiIfZzlCdE6syM" />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    
    <!-- Canonical -->
    <link rel="canonical" href={canonical} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, siteUrl)} />
    <meta property="og:site_name" content="ConnectologyIA" />
    <meta property="og:locale" content="es_PE" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonical} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(ogImage, siteUrl)} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    
    <slot name="head" />
  </head>
  <body class="min-h-screen bg-[#030712] flex flex-col selection:bg-cyan-500/30 text-slate-300">
    <!-- Skip to content -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 bg-cyan-500 text-white px-4 py-2 rounded-md z-[100]">
      Saltar al contenido
    </a>

    <Navbar currentPath={currentPath} client:only="react" />
    
    <div class="flex-grow flex flex-col">
      <slot />
    </div>
    
    <Footer client:idle />
    <WhatsAppButton client:idle />
  </body>
</html>
