{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "seoTitle": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "excerpt": {
      "type": "string"
    },
    "primaryKeyword": {
      "type": "string"
    },
    "secondaryKeywords": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "category": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "author": {
      "default": "Equipo ConnectologyIA",
      "type": "string"
    },
    "datePublished": {
      "type": "string"
    },
    "dateModified": {
      "type": "string"
    },
    "image": {
      "type": "string"
    },
    "imageAlt": {
      "type": "string"
    },
    "draft": {
      "default": false,
      "type": "boolean"
    },
    "featured": {
      "default": false,
      "type": "boolean"
    },
    "relatedPosts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "relatedServices": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "category",
    "tags",
    "datePublished"
  ]
}